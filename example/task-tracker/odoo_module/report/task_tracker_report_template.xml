<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_task_tracker_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row">
                            <div class="col-6">
                                <h2><t t-esc="doc.name"/></h2>
                                <p class="text-muted">Ref: <t t-esc="doc.reference"/></p>
                            </div>
                            <div class="col-6 text-end">
                                <span t-attf-class="badge bg-{{ 'success' if doc.state == 'done' else ('danger' if doc.state == 'cancelled' else 'warning') }}">
                                    <t t-esc="doc.state.upper()"/>
                                </span>
                            </div>
                        </div>
                        <hr/>
                        <!-- Body -->
                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Responsible:</strong>
                                <t t-esc="doc.user_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Company:</strong>
                                <t t-esc="doc.company_id.name"/>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Period:</strong>
                                <t t-esc="doc.date_start"/> — <t t-esc="doc.date_end"/>
                            </div>
                            <div class="col-6">
                                <strong>Duration:</strong>
                                <t t-esc="doc.duration_days"/> days
                            </div>
                        </div>
                        <t t-if="doc.description">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Description:</strong>
                                    <p><t t-esc="doc.description"/></p>
                                </div>
                            </div>
                        </t>
                        <!-- Footer -->
                        <div class="row mt-5">
                            <div class="col-12 text-muted text-center">
                                <small>Generated by create-odoo-module — https://create-odoo-module.dev</small>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
