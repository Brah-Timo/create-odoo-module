<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Groups -->
        <record id="group_task_tracker_user" model="res.groups">
            <field name="name">Task Tracker / User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
        <record id="group_task_tracker_manager" model="res.groups">
            <field name="name">Task Tracker / Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('group_task_tracker_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
